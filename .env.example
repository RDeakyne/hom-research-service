# Copy to .env and fill in. NEVER commit .env.
BASE44_APP_ID=693cc7b6bd22762dbbbfefba
BASE44_API_KEY=your_base44_api_key
BASE44_BASE_URL=https://app.base44.com
ANTHROPIC_API_KEY=your_anthropic_api_key
# Shared secret Base44 sends in the X-Run-Token header so randos can't trigger runs:
RUN_TOKEN=make_up_a_long_random_string
