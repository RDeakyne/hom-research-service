# Copy to .env and fill in. NEVER commit .env.
BASE44_APP_ID=693cc7b6bd22762dbbbfefba
BASE44_API_KEY=your_base44_api_key
BASE44_BASE_URL=https://app.base44.com
ANTHROPIC_API_KEY=your_anthropic_api_key
# Shared secret Base44 sends in the X-Run-Token header so randos can't trigger runs:
RUN_TOKEN=make_up_a_long_random_string
# Google Places API key — powers local competition density (Competitor Intelligence map).
# Optional: if unset, the competition block is skipped and everything else still runs.
GOOGLE_PLACES_API_KEY=your_google_places_api_key
# Manus API key — powers automated Meta Ad Library competitor ad teardown (v2, Phase 2).
# Optional: if unset, competitor ad intel falls back to manual Manus paste via /ingest-ad-intel.
MANUS_API_KEY=your_manus_api_key
